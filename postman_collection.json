{
  "info": {
    "name": "Library Management API - Postman",
    "_postman_id": "b3b6a7a4-0000-4000-8000-000000000001",
    "description": "Collection for Library Management System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "bookId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Add Book",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"The Great Gatsby\",\n  \"author\": \"Aditi Singh\",\n  \"isbn\": \"9780743273565\",\n  \"genre\": \"Classic Fiction\",\n  \"publisher\": \"Scribner\",\n  \"publicationYear\": 1925,\n  \"totalCopies\": 5,\n  \"availableCopies\": 5,\n  \"shelfLocation\": \"A1\",\n  \"bookType\": \"Circulating\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/books",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "books"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Response has _id', function () {",
              "  pm.expect(json._id).to.be.a('string');",
              "});",
              "pm.environment.set('bookId', json._id);",
              "pm.environment.set('createdIsbn', json.isbn);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get All Books",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/books",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "books"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Response is an array', function () {",
              "  pm.expect(Array.isArray(json)).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Search Books (title/author)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/books/search?title=Gatsby&author=Aditi",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "books",
            "search"
          ],
          "query": [
            {
              "key": "title",
              "value": "Gatsby"
            },
            {
              "key": "author",
              "value": "Aditi"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Response is array', function () {",
              "  pm.expect(Array.isArray(json)).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Book By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/books/{{bookId}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "books",
            "{{bookId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Returned id matches environment bookId', function () {",
              "  pm.expect(json._id).to.eql(pm.environment.get('bookId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Update Book",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"totalCopies\": 6,\n  \"availableCopies\": 6\n}"
        },
        "url": {
          "raw": "{{base_url}}/books/{{bookId}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "books",
            "{{bookId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('totalCopies updated', function () {",
              "  pm.expect(json.totalCopies).to.eql(6);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Delete Book",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/books/{{bookId}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "books",
            "{{bookId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Message present', function () {",
              "  pm.expect(json.message).to.be.a('string');",
              "});",
              "pm.environment.unset('bookId');"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
